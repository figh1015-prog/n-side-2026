{
  "name": "nside-pro",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "build": "vite build && node build-worker.mjs",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name nside-pro",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply nside-pro-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply nside-pro-production",
    "db:seed": "wrangler d1 execute nside-pro-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "hono": "^4.12.9",
    "lucide-react": "^1.6.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@hono/vite-cloudflare-pages": "^0.1.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
