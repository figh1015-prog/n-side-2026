{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nside-pro",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": "./dist",

  // Environment variables
  "vars": {
    "ENVIRONMENT": "production"
  },

  // D1 Database binding
  // Create with: npx wrangler d1 create nside-pro-production
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nside-pro-production",
      "database_id": "47551814-c07c-47de-bd88-483f95f4db61"
    }
  ],

  // KV Namespace binding
  // Create with: npx wrangler kv:namespace create CACHE
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "eab8dd026eea4c2381a4a626bb0c18f7",
      "preview_id": "eab8dd026eea4c2381a4a626bb0c18f7"
    }
  ]
}
